APP_NAME=luminapass
APP_PORT=3000
APP_ENV=development
APP_DEBUG=true
JWT_SECRET=your_jwt_secret_key
JSON_REQUEST_LIMIT=10mb

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

AMQP_URL=amqp://localhost
AMQP_PORT=5672
AMQP_USER=guest
AMQP_PASS=guest

EMAIL_FROM=no-reply@luminapass.local
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=your-gmail@gmail.com
EMAIL_SMTP_PASS=your-gmail-app-password
EMAIL_RETRY_MAX_ATTEMPTS=8
EMAIL_RETRY_BASE_SECONDS=60
EMAIL_WEBHOOK_URL=

LOADTEST_BASE_URL=http://host.docker.internal:3000
WEBHOOK_PROVIDER=mock
WEBHOOK_PROVIDER_ORDER_ID=ORD-LOAD-TEST
WEBHOOK_EXTERNAL_TXN_ID=MOCK-ORD-LOAD-TEST
LOADTEST_AUTH_TOKEN=
LOADTEST_RACE_EVENT_ID=
LOADTEST_RACE_SECTION_ID=
LOADTEST_RACE_PAYMENT_PROVIDER=mock
LOADTEST_RACE_QUANTITY=1
LOADTEST_RACE_VUS=500
LOADTEST_RACE_DURATION=60s
LOADTEST_ENABLE_PAYMENT=true